classDiagram
    class Customer {
        -id:int
        -name:String
        -email:String
    }

    class Product {
        -id:int
        -name:String
        -price:double
    }

    class Order {
        -id:int
        -totalPrice:double
    }

%% An order belongs to exactly one customer
    Order --> "1" Customer : belongsTo
%% An order contains one or more products
    Order --> "1..*" Product : contains
